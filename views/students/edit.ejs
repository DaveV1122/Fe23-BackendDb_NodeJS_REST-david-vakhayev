<%- include('../layout', { body: `
  <section class="page-header">
    <h2>Redigera student</h2>
    <a class="btn btn-secondary" href="/students">Tillbaka</a>
  </section>

  <section class="form-card">
    <form action="/students/${student.id}?_method=PUT" method="POST">
      <div class="form-group">
        <label for="fName">Förnamn</label>
        <input 
          type="text" 
          id="fName" 
          name="fName" 
          value="${student.fName}" 
          required
        >
      </div>

      <div class="form-group">
        <label for="lName">Efternamn</label>
        <input 
          type="text" 
          id="lName" 
          name="lName" 
          value="${student.lName}" 
          required
        >
      </div>

      <div class="form-group">
        <label for="town">Stad</label>
        <input 
          type="text" 
          id="town" 
          name="town" 
          value="${student.town || ''}"
        >
      </div>

      <button type="submit">Uppdatera student</button>
    </form>
  </section>
` }) %>