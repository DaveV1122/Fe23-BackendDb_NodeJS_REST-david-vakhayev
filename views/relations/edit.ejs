<%- include('../layout', { body: `
  <section class="page-header">
    <h2>Redigera relation</h2>
    <a class="btn btn-secondary" href="/relations">Tillbaka</a>
  </section>

  <section class="form-card">
    <form action="/relations/${relation.id}?_method=PUT" method="POST">
      <div class="form-group">
        <label for="students_id">Student</label>
        <select id="students_id" name="students_id" required>
          ${students.map(student => `
            <option value="${student.id}" ${student.id === relation.students_id ? 'selected' : ''}>
              ${student.id} - ${student.fName} ${student.lName}
            </option>
          `).join('')}
        </select>
      </div>

      <div class="form-group">
        <label for="courses_id">Kurs</label>
        <select id="courses_id" name="courses_id" required>
          ${courses.map(course => `
            <option value="${course.id}" ${course.id === relation.courses_id ? 'selected' : ''}>
              ${course.id} - ${course.name}
            </option>
          `).join('')}
        </select>
      </div>

      <button type="submit">Uppdatera relation</button>
    </form>
  </section>
` }) %>