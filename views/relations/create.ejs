<%- include('../layout', { body: `
  <section class="page-header">
    <h2>Lägg till relation</h2>
    <a class="btn btn-secondary" href="/relations">Tillbaka</a>
  </section>

  <section class="form-card">
    <form action="/relations" method="POST">
      <div class="form-group">
        <label for="students_id">Student</label>
        <select id="students_id" name="students_id" required>
          <option value="">Välj student</option>
          ${students.map(student => `
            <option value="${student.id}">
              ${student.id} - ${student.fName} ${student.lName}
            </option>
          `).join('')}
        </select>
      </div>

      <div class="form-group">
        <label for="courses_id">Kurs</label>
        <select id="courses_id" name="courses_id" required>
          <option value="">Välj kurs</option>
          ${courses.map(course => `
            <option value="${course.id}">
              ${course.id} - ${course.name}
            </option>
          `).join('')}
        </select>
      </div>

      <button type="submit">Spara relation</button>
    </form>
  </section>
` }) %>